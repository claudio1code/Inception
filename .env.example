# ============================================================================
# INCEPTION ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to '.env' and fill in the values according to your setup.

# The domain name mandated by the Subject (replace with your login)
DOMAIN_NAME=your_login.42.fr

# The name of the WordPress database instance
MYSQL_DATABASE=inception_db

# Host absolute paths for data persistence (usually inside /home/your_login/data)
WP_DATA_PATH=/home/your_login/data/wordpress
DB_DATA_PATH=/home/your_login/data/mariadb